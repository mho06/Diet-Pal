# Firebase (client-side config — safe to expose, restricted by Firestore rules)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# AI keys — SERVER-SIDE ONLY. Never referenced from frontend code.
# Set these in Netlify's dashboard (Site settings > Environment variables),
# not just in this local file.
GEMINI_API_KEY=
GROQ_API_KEY=
