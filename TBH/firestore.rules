rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Daily food logs, nested under the user
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Dish knowledge base (RAG source data) — readable by any signed-in user,
    // writable only via the backend (Admin SDK bypasses rules, so no client writes allowed).
    match /dishes/{dishId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
